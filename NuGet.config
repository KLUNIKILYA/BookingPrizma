<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Локальный источник пакетов: только официальный nuget.org.
       Глобальные источники (DevExpress и пр.) очищаются, т.к. проекту они не нужны
       и приватный DevExpress-фид возвращал 401, ломая весь restore. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
