@inject BookingApi Api
@inject IJSRuntime JS

@if (_visible)
{
    <div class="bk-modal-backdrop" @onclick="Cancel">
        <div class="bk-modal @(_fullscreen ? "bk-modal--full" : "")" @onclick:stopPropagation="true">
            <div class="bk-modal__head">
                <div class="bk-modal__title">@HeadTitle</div>
                <div class="bk-modal__head-actions">
                    <button type="button" class="bk-modal__icon" @onclick="ToggleFullscreen"
                            title="@(_fullscreen ? "Свернуть окно" : "Открыть во весь экран")">
                        @if (_fullscreen)
                        {
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M9.5 6.5h-3v-3M6.5 6.5l-3-3M6.5 9.5h-3v3M6.5 9.5l-3 3M9.5 9.5h3v3M9.5 9.5l3 3M9.5 6.5h3v-3M9.5 6.5l3-3" />
                            </svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M6 2.5H2.5V6M10 2.5h3.5V6M6 13.5H2.5V10M10 13.5h3.5V10" />
                            </svg>
                        }
                    </button>
                    <button type="button" class="bk-modal__close" @onclick="Cancel">✕</button>
                </div>
            </div>

            @if (_readOnly)
            {
                <div class="bk-error" style="color:#23306b;">Бронь кассовой системы — только просмотр.</div>
            }
            @if (_error is not null)
            {
                <div class="bk-alert" role="alert">@_error</div>
            }

            <fieldset disabled="@_readOnly" style="border:none; padding:0; margin:0; min-width:0;">
            <div class="bk-modal__body">
                <!-- ЛЕВО: данные брони + клиент -->
                <div>
                    <p class="bk-section-title">Клиент</p>
                    <div class="bk-form-row bk-autocomplete">
                        <label>@(_clientId.HasValue ? $"Выбран: {_clientName}" : "Поиск в базе по фамилии")</label>
                        <div class="bk-client-row">
                            <input class="bk-input" value="@_clientQuery" @oninput="OnClientInput"
                                   @onfocus="() => _showSuggest = _suggestions.Count > 0"
                                   placeholder="Введите фамилию…" />
                            <button type="button" class="bk-btn bk-btn--ghost" @onclick="ToggleNewClient">
                                @(_newClientMode ? "Отмена" : "+ Новый")
                            </button>
                        </div>
                        @if (_showSuggest && _suggestions.Count > 0 && !_newClientMode)
                        {
                            <div class="bk-suggest">
                                @foreach (var c in _suggestions)
                                {
                                    <div class="bk-suggest__item" @onclick="() => PickClient(c)">
                                        @c.FullName
                                        @if (!string.IsNullOrWhiteSpace(c.Phone))
                                        {
                                            <span class="bk-suggest__phone"> · @c.Phone</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (_newClientMode)
                    {
                        <div class="bk-newclient">
                            <div class="bk-row-2">
                                <div class="bk-form-row">
                                    <label>Фамилия</label>
                                    <input class="bk-input" @bind="_ncSurname" />
                                </div>
                                <div class="bk-form-row">
                                    <label>Имя</label>
                                    <input class="bk-input" @bind="_ncName" />
                                </div>
                            </div>
                            <div class="bk-form-row">
                                <label>Телефон</label>
                                <input class="bk-input" @bind="_ncPhone" placeholder="необязательно" />
                            </div>
                            <button type="button" class="bk-btn" @onclick="CreateClientAsync" disabled="@_busy">Создать и выбрать</button>
                        </div>
                    }

                    <div class="bk-form-row">
                        <label>@(_editingId.HasValue ? "Комната" : "Комнаты")</label>
                        @if (_editingId.HasValue)
                        {
                            <select @bind="_singleRoomId" @bind:after="OnRoomChanged">
                                @foreach (var r in Resources)
                                {
                                    var busy = RoomBusy(r.Id);
                                    <option value="@r.Id" disabled="@(busy is not null && r.Id != _singleRoomId)">
                                        @r.DisplayName@(busy is not null ? $" — занята до {busy.TimeTo:HH:mm}" : "")
                                    </option>
                                }
                            </select>
                        }
                        else
                        {
                            <div class="bk-room-multi">
                                @foreach (var r in Resources)
                                {
                                    var busy = RoomBusy(r.Id);
                                    <label class="bk-room-multi__item @(busy is not null ? "is-busy" : "")">
                                        <input type="checkbox" disabled="@(busy is not null)" checked="@_roomIds.Contains(r.Id)"
                                               @onchange="e => OnRoomToggle(r.Id, (bool)(e.Value ?? false))" />
                                        <span>@r.DisplayName</span>
                                        @if (busy is not null)
                                        {
                                            <span class="bk-busy-note">занята до @busy.TimeTo.ToString("HH:mm")@(string.IsNullOrWhiteSpace(busy.Title) ? "" : " · " + busy.Title)</span>
                                        }
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class="bk-form-row">
                        <label>Официант</label>
                        <select @bind="_waiterId">
                            <option value="0">— не задан —</option>
                            @foreach (var w in Waiters)
                            {
                                var wbusy = WaiterBusy(w.Id);
                                <option value="@w.Id" disabled="@(wbusy is not null && w.Id != _waiterId)">
                                    @w.FullName@(wbusy is not null ? $" — занят до {wbusy.TimeTo:HH:mm}" : "")
                                </option>
                            }
                        </select>
                    </div>

                    <div class="bk-row-2">
                        <div class="bk-form-row">
                            <label>Дата начала</label>
                            <input type="date" @bind="_date" @bind:after="RefreshAvailabilityAsync" />
                        </div>
                        <div class="bk-form-row">
                            <label>Время начала</label>
                            <select @bind="_time" @bind:after="RefreshAvailabilityAsync">
                                @foreach (var t in TimeOptions(_time))
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="bk-row-2">
                        <div class="bk-form-row">
                            <label>Дата окончания</label>
                            <input type="date" @bind="_endDate" @bind:after="RefreshAvailabilityAsync" />
                        </div>
                        <div class="bk-form-row">
                            <label>Время окончания</label>
                            <select @bind="_endTime" @bind:after="RefreshAvailabilityAsync">
                                @foreach (var t in TimeOptions(_endTime))
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (EndDateTime <= StartDateTime)
                    {
                        <div class="bk-warn">⚠ Время окончания должно быть позже начала.</div>
                    }

                    <div class="bk-form-row">
                        <label>Метка</label>
                        <select @bind="_labelValue">
                            @foreach (var l in BookingLabelInfo.All)
                            {
                                <option value="@((int)l.Label)">@l.Name</option>
                            }
                        </select>
                    </div>

                    <div class="bk-form-row">
                        <label>Примечание / пожелания по празднованию</label>
                        <textarea @bind="_note" placeholder="Комментарии клиента по празднованию"></textarea>
                    </div>

                    <p class="bk-section-title">Именинник</p>
                    <div class="bk-row-2">
                        <div class="bk-form-row">
                            <label>Имя именинника</label>
                            <input class="bk-input" @bind="_celebrantName" placeholder="необязательно" />
                        </div>
                        <div class="bk-form-row">
                            <label>Дата рождения</label>
                            <input type="date" @bind="_celebrantBirth" />
                        </div>
                    </div>

                    <div class="bk-form-row">
                        <label>Предоплата</label>
                        <div style="display:flex; align-items:center; gap:8px;">
                            <input type="checkbox" id="bk-prepaid" @bind="_isPrepaid" />
                            <label for="bk-prepaid" style="margin:0; font-weight:normal; white-space:nowrap;">внесена</label>
                            <input type="number" min="0" step="0.01" class="bk-input" style="flex:1;"
                                   placeholder="сумма" @bind="_prepaidAmount" disabled="@(!_isPrepaid)" />
                        </div>
                    </div>
                </div>

                <!-- ПРАВО: услуги (позиции с ценой, без времени) -->
                <div>
                    <div class="bk-form-row">
                        <label>Группа услуг</label>
                        <select @bind="_groupId" @bind:after="ReloadAvailableAsync">
                            <option value="0">+ ПОЛНЫЙ СПИСОК</option>
                            @foreach (var g in Groups)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    </div>

                    <p class="bk-section-title">Список доступных услуг</p>
                    <div class="bk-grid bk-grid--svc">
                        <div class="bk-grid__head">
                            <div>Название</div><div class="bk-grid__num">Цена</div>
                        </div>
                        <div class="bk-grid__scroll">
                            @if (_available.Count == 0)
                            {
                                <div class="bk-grid__empty">Нет услуг в группе</div>
                            }
                            @foreach (var s in _available)
                            {
                                <div class="bk-grid__row" @onclick="() => AddService(s)" title="Добавить в запись">
                                    <div>@s.Name</div>
                                    <div class="bk-grid__num">@s.Price.ToString("0.##")</div>
                                </div>
                            }
                        </div>
                    </div>

                    <p class="bk-section-title" style="margin-top:14px;">Билеты (взрослый / детский / сопровождающий)</p>
                    <div class="bk-form-row bk-autocomplete">
                        <input class="bk-input" value="@_ticketQuery" @oninput="OnTicketInput"
                               @onfocus="() => _showTicketSuggest = _ticketResults.Count > 0"
                               placeholder="Поиск билета по названию…" />
                        @if (_showTicketSuggest && _ticketResults.Count > 0)
                        {
                            <div class="bk-suggest">
                                @foreach (var t in _ticketResults)
                                {
                                    <div class="bk-suggest__item" @onclick="() => AddTicket(t)">
                                        @t.Name<span class="bk-suggest__phone"> · @t.Price.ToString("0.##")</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <p class="bk-section-title" style="margin-top:14px;">Список выбранных услуг</p>
                    <div class="bk-grid bk-grid--sel2">
                        <div class="bk-grid__head">
                            <div>Название</div><div class="bk-grid__num">Цена</div><div class="bk-grid__num">Кол-во</div><div class="bk-grid__num">Сумма</div><div></div>
                        </div>
                        <div class="bk-grid__scroll">
                            @if (_selected.Count == 0)
                            {
                                <div class="bk-grid__empty">Кликните услугу слева, чтобы добавить</div>
                            }
                            @for (var i = 0; i < _selected.Count; i++)
                            {
                                var idx = i;
                                var line = _selected[idx];
                                <div class="bk-grid__row">
                                    <div>@(line.IsTicket ? "🎟 " : "")@line.Name</div>
                                    <div class="bk-grid__num">@line.Price.ToString("0.##")</div>
                                    <div class="bk-grid__num">
                                        <input type="number" min="1" step="1" class="bk-qty"
                                               @bind="line.Quantity" @bind:after="() => ClampQty(line)" />
                                    </div>
                                    <div class="bk-grid__num">@((line.Price * line.Quantity).ToString("0.##"))</div>
                                    <div><button class="bk-icon-btn" @onclick="() => RemoveAt(idx)" title="Убрать">🗑</button></div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="bk-sums">
                        <span>Длительность: <b>@DurationText</b></span>
                        <span>Аренда: <b>@TariffSum.ToString("0.##")</b></span>
                        <span>Сумма: <b>@TotalPrice.ToString("0.##")</b></span>
                    </div>
                </div>
            </div>
            </fieldset>

            <div class="bk-modal__foot">
                @if (_readOnly)
                {
                    <button type="button" class="bk-btn bk-btn--ghost" style="margin-right:auto;" @onclick="PrintAsync">🖨 Печать для кафе</button>
                    <button class="bk-btn bk-btn--ghost" @onclick="Cancel">Закрыть</button>
                }
                else
                {
                    @if (_editingId.HasValue)
                    {
                        <button class="bk-btn bk-btn--danger" @onclick="DeleteAsync" disabled="@_busy">Удалить</button>
                    }
                    <button type="button" class="bk-btn bk-btn--ghost" style="margin-right:auto;" @onclick="PrintAsync">🖨 Печать для кафе</button>
                    <button class="bk-btn bk-btn--ghost" @onclick="Cancel" disabled="@_busy">Отмена</button>
                    <button class="bk-btn" @onclick="SaveAsync" disabled="@_busy">Сохранить</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public List<ResourceDto> Resources { get; set; } = new();
    [Parameter] public List<ServiceGroupDto> Groups { get; set; } = new();
    [Parameter] public List<ClientDto> Waiters { get; set; } = new();

    /// <summary>Вызывается после успешного создания/изменения/удаления — родитель перезагружает сетку.</summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _visible;
    private bool _busy;
    private bool _fullscreen; // окно развёрнуто на весь экран
    private bool _readOnly;   // true для кассовых броней (OrderID != null)
    private string? _error;
    private int? _editingId;

    // поля формы
    private string _title = "";
    private readonly HashSet<int> _roomIds = new();   // выбранные комнаты (создание — несколько, правка — одна)
    private int _waiterId; // 0 = не задан

    /// <summary>Одиночная комната для режима правки (биндинг select).</summary>
    private int _singleRoomId
    {
        get => _roomIds.Count > 0 ? _roomIds.First() : 0;
        set { _roomIds.Clear(); if (value > 0) _roomIds.Add(value); }
    }

    private async Task OnRoomToggle(int id, bool on)
    {
        if (on) _roomIds.Add(id); else _roomIds.Remove(id);
        await ReloadTariffsAsync();
    }

    private async Task OnRoomChanged()
    {
        await ReloadTariffsAsync();
        await RefreshAvailabilityAsync();
    }

    private List<int> SelectedRooms() =>
        _editingId.HasValue
            ? (_singleRoomId > 0 ? new List<int> { _singleRoomId } : new List<int>())
            : _roomIds.ToList();

    /// <summary>Грузит тарифы по всем выбранным комнатам (для авто-расчёта аренды). Менеджер тариф не выбирает.</summary>
    private async Task ReloadTariffsAsync()
    {
        var map = new Dictionary<int, List<TariffDto>>();
        foreach (var rid in SelectedRooms())
            map[rid] = await Api.GetTariffsAsync(rid);
        _tariffsByRoom = map;
        StateHasChanged();
    }

    private DateTime _date = DateTime.Today;
    private string _time = "10:00";       // "HH:mm", 24ч
    private DateTime _endDate = DateTime.Today;
    private string _endTime = "11:00";    // "HH:mm", 24ч
    private int _labelValue;
    private string? _note;

    // именинник + предоплата
    private string? _celebrantName;
    private DateTime? _celebrantBirth;
    private bool _isPrepaid;
    private decimal _prepaidAmount;

    // клиент
    private int? _clientId;
    private string _clientName = "";
    private string _clientQuery = "";
    private List<ClientDto> _suggestions = new();
    private bool _showSuggest;

    // создание нового клиента
    private bool _newClientMode;
    private string _ncSurname = "";
    private string _ncName = "";
    private string _ncPhone = "";

    // услуги
    private int _groupId; // 0 = полный список
    private List<ServiceDto> _available = new();
    private readonly List<SelectedLine> _selected = new();

    // тарифы аренды по каждой выбранной комнате — для авто-расчёта (менеджер их не выбирает).
    private Dictionary<int, List<TariffDto>> _tariffsByRoom = new();

    // поиск билетов-услуг (взрослый/детский/сопровождающий)
    private string _ticketQuery = "";
    private List<TicketDto> _ticketResults = new();
    private bool _showTicketSuggest;

    // занятость на выбранный интервал (для блокировки комнат/официантов)
    private Dictionary<int, BusySlotDto> _busyRooms = new();
    private Dictionary<int, BusySlotDto> _busyWaiters = new();

    private BusySlotDto? RoomBusy(int id) => _busyRooms.GetValueOrDefault(id);
    private BusySlotDto? WaiterBusy(int id) => _busyWaiters.GetValueOrDefault(id);

    private string HeadTitle => _readOnly ? "Просмотр брони" : (_editingId.HasValue ? "Редактирование записи" : "Новая запись");

    /// <summary>Длительность брони в минутах (по выбранному времени).</summary>
    private int BookingMinutes => (int)Math.Max(0, (EndDateTime - StartDateTime).TotalMinutes);

    /// <summary>Авто-цена аренды комнаты: самый дешёвый тариф, чья длительность покрывает бронь
    /// (округление вверх до тарифа); если бронь длиннее всех тарифов — самый длинный.</summary>
    private static decimal AutoTariffPrice(List<TariffDto> tariffs, int minutes)
    {
        if (minutes <= 0 || tariffs.Count == 0) return 0m;
        var cover = tariffs.Where(t => t.Minutes >= minutes)
                           .OrderBy(t => t.Minutes).ThenBy(t => t.Price).FirstOrDefault();
        return cover?.Price
            ?? tariffs.OrderByDescending(t => t.Minutes).ThenBy(t => t.Price).First().Price;
    }

    /// <summary>Сумма аренды по всем выбранным комнатам (авто по длительности брони).</summary>
    private decimal TariffSum
    {
        get
        {
            var mins = BookingMinutes;
            if (mins <= 0) return 0m;
            decimal sum = 0m;
            foreach (var rid in SelectedRooms())
                if (_tariffsByRoom.TryGetValue(rid, out var list))
                    sum += AutoTariffPrice(list, mins);
            return sum;
        }
    }
    private decimal TotalPrice => _selected.Sum(s => s.Price * Math.Max(1, s.Quantity)) + TariffSum;

    private void ToggleFullscreen() => _fullscreen = !_fullscreen;

    private static void ClampQty(SelectedLine line)
    {
        if (line.Quantity < 1) line.Quantity = 1;
    }
    private DateTime StartDateTime => _date.Date + ParseTime(_time, 10);
    private DateTime EndDateTime => _endDate.Date + ParseTime(_endTime, 11);

    // 24-часовая сетка времени (нативный input type=time зависит от локали браузера и показывает AM/PM).
    private static readonly string[] TimeGrid = BuildTimeGrid();

    private static string[] BuildTimeGrid()
    {
        var list = new List<string>();
        for (var h = 0; h < 24; h++)
            for (var m = 0; m < 60; m += 15)
                list.Add($"{h:00}:{m:00}");
        return list.ToArray();
    }

    private static IEnumerable<string> TimeOptions(string current) =>
        string.IsNullOrEmpty(current) || TimeGrid.Contains(current)
            ? TimeGrid
            : TimeGrid.Append(current).OrderBy(x => x);

    private static TimeSpan ParseTime(string s, int fallbackHour) =>
        TimeSpan.TryParse(s, out var ts) ? ts : TimeSpan.FromHours(fallbackHour);

    private string DurationText
    {
        get
        {
            var span = EndDateTime - StartDateTime;
            if (span <= TimeSpan.Zero) return "0 мин";
            return span.TotalDays >= 1
                ? $"{(int)span.TotalDays} дн {span.Hours:00}:{span.Minutes:00}"
                : $"{(int)span.TotalMinutes} мин";
        }
    }

    public async Task OpenForCreateAsync(int resourceId, DateTime start)
    {
        InitCommon(new[] { resourceId }, start, start.AddHours(1));
        await ReloadAvailableAsync();
        await ReloadTariffsAsync();
        await RefreshAvailabilityAsync();
        StateHasChanged();
    }

    /// <summary>Создание сразу для нескольких комнат на выделенный период (из выделения сетки).</summary>
    public async Task OpenForCreateMultiAsync(IEnumerable<int> resourceIds, DateTime start, DateTime end)
    {
        if (end <= start) end = start.AddHours(1);
        InitCommon(resourceIds, start, end);
        await ReloadAvailableAsync();
        await ReloadTariffsAsync();
        await RefreshAvailabilityAsync();
        StateHasChanged();
    }

    private void InitCommon(IEnumerable<int> resourceIds, DateTime start, DateTime end)
    {
        _editingId = null;
        _readOnly = false;
        _title = "";
        _roomIds.Clear();
        foreach (var id in resourceIds)
            if (id > 0) _roomIds.Add(id);
        _waiterId = 0;
        _date = start.Date;
        _time = start.ToString("HH:mm");
        _endDate = end.Date;
        _endTime = end.ToString("HH:mm");
        _labelValue = 0;
        _note = null;
        _celebrantName = null; _celebrantBirth = null; _isPrepaid = false; _prepaidAmount = 0;
        _clientId = null; _clientName = ""; _clientQuery = ""; _suggestions.Clear(); _showSuggest = false;
        _newClientMode = false; _ncSurname = ""; _ncName = ""; _ncPhone = "";
        _groupId = 0;
        _selected.Clear();
        _tariffsByRoom = new();
        _ticketQuery = ""; _ticketResults.Clear(); _showTicketSuggest = false;
        _busyRooms.Clear();
        _busyWaiters.Clear();
        _error = null;
        _visible = true;
    }

    public async Task OpenForEditAsync(BookingEventDto dto)
    {
        _editingId = dto.Id;
        _readOnly = !dto.CanEdit;   // кассовые брони — только просмотр
        _title = dto.Title;
        _roomIds.Clear();
        _roomIds.Add(dto.ResourceId);
        _waiterId = dto.WaiterVisitorId ?? 0;
        _date = dto.TimeFrom.Date;
        _time = dto.TimeFrom.ToString("HH:mm");
        _endDate = dto.TimeTo.Date;
        _endTime = dto.TimeTo.ToString("HH:mm");
        _labelValue = (int)dto.Label;
        _note = dto.Note;
        _celebrantName = dto.CelebrantName;
        _celebrantBirth = dto.CelebrantBirthDate;
        _isPrepaid = dto.IsPrepaid;
        _prepaidAmount = dto.PrepaidAmount ?? 0;
        _clientId = dto.ClientVisitorId;
        _clientName = dto.ClientName ?? "";
        _clientQuery = dto.ClientName ?? "";
        _suggestions.Clear(); _showSuggest = false;
        _newClientMode = false; _ncSurname = ""; _ncName = ""; _ncPhone = "";
        _groupId = 0;
        _selected.Clear();
        foreach (var s in dto.Services)
            _selected.Add(new SelectedLine
            {
                ServiceId = s.ServiceId, Name = s.ServiceName, Price = s.Price,
                Quantity = s.Quantity < 1 ? 1 : s.Quantity, IsDone = s.IsDone, IsTicket = s.IsTicket
            });
        _ticketQuery = ""; _ticketResults.Clear(); _showTicketSuggest = false;
        _error = null;
        _visible = true;
        _busyRooms.Clear();
        _busyWaiters.Clear();
        await ReloadAvailableAsync();
        await ReloadTariffsAsync();
        await RefreshAvailabilityAsync();
        StateHasChanged();
    }

    /// <summary>Запрашивает занятость комнат/официантов на выбранный интервал и блокирует занятые.</summary>
    private async Task RefreshAvailabilityAsync()
    {
        if (_readOnly) return;
        if (EndDateTime <= StartDateTime)
        {
            _busyRooms.Clear();
            _busyWaiters.Clear();
            return;
        }

        AvailabilityDto av;
        try { av = await Api.GetAvailabilityAsync(StartDateTime, EndDateTime, _editingId); }
        catch { return; }

        // для каждой комнаты/официанта берём самую позднюю занятость («занято до …»)
        _busyRooms = av.Rooms.GroupBy(r => r.Id)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(x => x.TimeTo).First());
        _busyWaiters = av.Waiters.GroupBy(w => w.Id)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(x => x.TimeTo).First());

        // снимаем галочки с комнат, ставших занятыми в новом интервале
        foreach (var id in _roomIds.Where(id => _busyRooms.ContainsKey(id)).ToList())
            _roomIds.Remove(id);

        StateHasChanged();
    }

    private async Task ReloadAvailableAsync()
    {
        _available = await Api.GetServicesAsync(_groupId == 0 ? null : _groupId);
        StateHasChanged();
    }

    private void AddService(ServiceDto s)
    {
        if (_readOnly) return;
        _selected.Add(new SelectedLine { ServiceId = s.Id, Name = s.Name, Price = s.Price, IsDone = false });
    }

    private async Task OnTicketInput(ChangeEventArgs e)
    {
        _ticketQuery = e.Value?.ToString() ?? "";
        var q = _ticketQuery.Trim();
        if (q.Length >= 2)
        {
            _ticketResults = await Api.SearchTicketsAsync(q, 8);
            _showTicketSuggest = true;
        }
        else
        {
            _ticketResults.Clear();
            _showTicketSuggest = false;
        }
    }

    private void AddTicket(TicketDto t)
    {
        if (_readOnly) return;
        _selected.Add(new SelectedLine { ServiceId = t.TicketId, Name = t.Name, Price = t.Price, IsTicket = true, IsDone = false });
        _ticketQuery = "";
        _ticketResults.Clear();
        _showTicketSuggest = false;
    }

    private void RemoveAt(int idx)
    {
        if (_readOnly) return;
        if (idx >= 0 && idx < _selected.Count) _selected.RemoveAt(idx);
    }

    private async Task OnClientInput(ChangeEventArgs e)
    {
        _clientQuery = e.Value?.ToString() ?? "";
        _clientId = null;
        _clientName = "";
        var q = _clientQuery.Trim();
        if (q.Length >= 2)
        {
            _suggestions = await Api.SearchClientsAsync(q, 8);
            _showSuggest = true;
        }
        else
        {
            _suggestions.Clear();
            _showSuggest = false;
        }
    }

    private void PickClient(ClientDto c)
    {
        _clientId = c.Id;
        _clientName = c.FullName;
        _clientQuery = c.FullName;
        _title = c.FullName;
        _showSuggest = false;
        _newClientMode = false;
    }

    private void ToggleNewClient()
    {
        _newClientMode = !_newClientMode;
        if (_newClientMode)
        {
            _showSuggest = false;
            _ncSurname = _clientQuery.Trim();
            _ncName = "";
            _ncPhone = "";
        }
    }

    private async Task CreateClientAsync()
    {
        if (string.IsNullOrWhiteSpace(_ncSurname) && string.IsNullOrWhiteSpace(_ncName))
        {
            _error = "Укажите фамилию или имя нового клиента.";
            return;
        }
        _busy = true; _error = null;
        try
        {
            var created = await Api.CreateClientAsync(new CreateClientRequest
            {
                Surname = _ncSurname.Trim(),
                Name = _ncName.Trim(),
                Phone = string.IsNullOrWhiteSpace(_ncPhone) ? null : _ncPhone.Trim()
            });
            if (created is null) { _error = "Не удалось создать клиента."; return; }
            PickClient(created);
        }
        finally { _busy = false; }
    }

    private async Task SaveAsync()
    {
        if (_roomIds.Count == 0) { _error = _editingId.HasValue ? "Выберите комнату." : "Выберите хотя бы одну комнату."; return; }
        if (_clientId == null && string.IsNullOrWhiteSpace(_title)) { _error = "Выберите клиента или создайте нового."; return; }
        if (EndDateTime <= StartDateTime) { _error = "Окончание должно быть позже начала."; return; }

        _busy = true; _error = null;
        try
        {
            BookingUpsertRequest Build(int roomId) => new()
            {
                ResourceId = roomId,
                TimeFrom = StartDateTime,
                TimeToOverride = EndDateTime,
                Title = _title.Trim(),
                ClientVisitorId = _clientId,
                WaiterVisitorId = _waiterId > 0 ? _waiterId : null,
                Label = (BookingLabel)_labelValue,
                Note = _note,
                CelebrantName = string.IsNullOrWhiteSpace(_celebrantName) ? null : _celebrantName.Trim(),
                CelebrantBirthDate = _celebrantBirth,
                IsPrepaid = _isPrepaid,
                PrepaidAmount = _isPrepaid ? _prepaidAmount : (decimal?)null,
                Services = _selected.Select(s => new BookingServiceSelection { ServiceId = s.ServiceId, Quantity = s.Quantity, IsDone = s.IsDone, IsTicket = s.IsTicket }).ToList()
            };

            if (_editingId.HasValue)
            {
                var res = await Api.UpdateAsync(_editingId.Value, Build(_roomIds.First()));
                if (!res.Ok)
                {
                    _error = BuildSaveError(res);
                    await RefreshAvailabilityAsync(); // подсветим занятость, чтобы было видно конфликт
                    return;
                }
            }
            else
            {
                // По одной брони на каждую выбранную комнату. Успешные убираем,
                // чтобы повторное сохранение не создавало дубликаты.
                var created = new List<int>();
                var errors = new List<string>();
                foreach (var roomId in _roomIds.ToList())
                {
                    var res = await Api.CreateAsync(Build(roomId));
                    if (res.Ok) created.Add(roomId);
                    else errors.Add(BuildSaveError(res));
                }
                foreach (var id in created) _roomIds.Remove(id);

                if (_roomIds.Count > 0)
                {
                    _error = string.Join(" ", errors.Distinct());
                    await OnChanged.InvokeAsync();      // показать уже созданные брони на сетке
                    await RefreshAvailabilityAsync();   // обновить занятость в окне
                    return;
                }
            }

            _visible = false;
            await OnChanged.InvokeAsync();
        }
        finally { _busy = false; }
    }

    /// <summary>Сообщение об ошибке сохранения: подробности по конфликту времени, либо текст ошибки.</summary>
    private static string BuildSaveError(BookingSaveResult res)
    {
        if (res.Conflicts.Count > 0)
            return string.Join(" ", res.Conflicts.Select(c =>
                $"❌ {c.ResourceName} уже забронирована на это время " +
                $"({(string.IsNullOrWhiteSpace(c.Title) ? "бронь" : c.Title)}, {c.TimeFrom:HH:mm}–{c.TimeTo:HH:mm})."));
        return res.Error ?? "Не удалось сохранить запись.";
    }

    private async Task DeleteAsync()
    {
        if (!_editingId.HasValue) return;
        _busy = true; _error = null;
        try
        {
            if (await Api.DeleteAsync(_editingId.Value))
            {
                _visible = false;
                await OnChanged.InvokeAsync();
            }
            else { _error = "Не удалось удалить запись."; }
        }
        finally { _busy = false; }
    }

    private void Cancel() => _visible = false;

    /// <summary>Печать листа брони для кафе: формируем HTML по текущим данным окна и открываем окно печати.</summary>
    private async Task PrintAsync()
    {
        await JS.InvokeVoidAsync("bkPrint", BuildPrintHtml());
    }

    private string BuildPrintHtml()
    {
        static string E(string? s) => System.Net.WebUtility.HtmlEncode(s ?? "");
        var sb = new System.Text.StringBuilder();

        var rooms = string.Join(", ", Resources.Where(r => _roomIds.Contains(r.Id)).Select(r => r.DisplayName));
        if (string.IsNullOrWhiteSpace(rooms)) rooms = "—";
        var clientName = !string.IsNullOrWhiteSpace(_clientName) ? _clientName
            : (!string.IsNullOrWhiteSpace(_title) ? _title : "—");
        var waiterName = Waiters.FirstOrDefault(w => w.Id == _waiterId)?.FullName;
        var labelName = BookingLabelInfo.Name((BookingLabel)_labelValue);

        sb.Append("<!DOCTYPE html><html lang='ru'><head><meta charset='utf-8'><title>Бронь для кафе</title><style>");
        sb.Append("*{box-sizing:border-box}body{font-family:'Segoe UI',Arial,sans-serif;color:#1a1a1a;margin:24px;font-size:14px}");
        sb.Append("h1{font-size:20px;margin:0 0 4px}.muted{color:#666;font-size:12px;margin:0 0 16px}");
        sb.Append(".sec{font-weight:600;font-size:13px;text-transform:uppercase;color:#445;margin:18px 0 6px;border-bottom:1px solid #ccc;padding-bottom:3px}");
        sb.Append(".row{display:flex;margin:3px 0}.row .k{width:210px;color:#555}.row .v{font-weight:600}");
        sb.Append("table{width:100%;border-collapse:collapse;margin-top:6px}th,td{border:1px solid #ccc;padding:6px 8px;text-align:left}th{background:#f2f4f8;font-size:12px}td.n,th.n{text-align:right}");
        sb.Append(".tot{margin-top:10px;text-align:right;font-size:15px}.tot b{font-size:18px}");
        sb.Append(".note{white-space:pre-wrap;border:1px solid #ccc;padding:8px;border-radius:4px;background:#fafafa}");
        sb.Append("@media print{body{margin:0}}</style></head><body>");

        sb.Append("<h1>Бронь — лист для кафе</h1>");
        sb.Append($"<p class='muted'>Распечатано: {E(DateTime.Now.ToString("dd.MM.yyyy HH:mm"))}</p>");

        sb.Append("<div class='sec'>Бронирование</div>");
        sb.Append($"<div class='row'><div class='k'>Комната(ы)</div><div class='v'>{E(rooms)}</div></div>");
        sb.Append($"<div class='row'><div class='k'>Дата и время</div><div class='v'>{E(StartDateTime.ToString("dd.MM.yyyy HH:mm"))} – {E(EndDateTime.ToString("dd.MM.yyyy HH:mm"))}</div></div>");
        sb.Append($"<div class='row'><div class='k'>Длительность</div><div class='v'>{E(DurationText)}</div></div>");
        sb.Append($"<div class='row'><div class='k'>Метка</div><div class='v'>{E(labelName)}</div></div>");

        sb.Append("<div class='sec'>Клиент</div>");
        sb.Append($"<div class='row'><div class='k'>Клиент</div><div class='v'>{E(clientName)}</div></div>");
        if (!string.IsNullOrWhiteSpace(waiterName))
            sb.Append($"<div class='row'><div class='k'>Официант</div><div class='v'>{E(waiterName)}</div></div>");

        if (!string.IsNullOrWhiteSpace(_celebrantName) || _celebrantBirth.HasValue)
        {
            sb.Append("<div class='sec'>Именинник</div>");
            sb.Append($"<div class='row'><div class='k'>Имя</div><div class='v'>{E(string.IsNullOrWhiteSpace(_celebrantName) ? "—" : _celebrantName)}</div></div>");
            sb.Append($"<div class='row'><div class='k'>Дата рождения</div><div class='v'>{(_celebrantBirth.HasValue ? E(_celebrantBirth.Value.ToString("dd.MM.yyyy")) : "—")}</div></div>");
        }

        sb.Append("<div class='sec'>Предзаказ по меню</div>");
        if (_selected.Count == 0)
            sb.Append("<p class='muted'>Позиции не выбраны.</p>");
        else
        {
            sb.Append("<table><thead><tr><th>Наименование</th><th class='n'>Цена</th><th class='n'>Кол-во</th><th class='n'>Сумма</th></tr></thead><tbody>");
            foreach (var s in _selected)
            {
                var name = (s.IsTicket ? "Билет: " : "") + s.Name;
                var qty = Math.Max(1, s.Quantity);
                sb.Append($"<tr><td>{E(name)}</td><td class='n'>{s.Price.ToString("0.##")}</td><td class='n'>{qty}</td><td class='n'>{(s.Price * qty).ToString("0.##")}</td></tr>");
            }
            sb.Append("</tbody></table>");
        }

        sb.Append("<div class='sec'>Оплата</div>");
        sb.Append($"<div class='row'><div class='k'>Аренда комнат</div><div class='v'>{TariffSum.ToString("0.##")}</div></div>");
        sb.Append($"<div class='row'><div class='k'>Предоплата</div><div class='v'>{(_isPrepaid ? $"внесена · {_prepaidAmount.ToString("0.##")}" : "нет")}</div></div>");
        sb.Append($"<div class='tot'>Итого: <b>{TotalPrice.ToString("0.##")}</b>");
        if (_isPrepaid)
            sb.Append($" &nbsp; · &nbsp; К доплате: <b>{(TotalPrice - _prepaidAmount).ToString("0.##")}</b>");
        sb.Append("</div>");

        if (!string.IsNullOrWhiteSpace(_note))
        {
            sb.Append("<div class='sec'>Комментарии по празднованию</div>");
            sb.Append($"<div class='note'>{E(_note)}</div>");
        }

        sb.Append("</body></html>");
        return sb.ToString();
    }

    private class SelectedLine
    {
        public int ServiceId { get; set; }
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public int Quantity { get; set; } = 1;
        public bool IsDone { get; set; }
        public bool IsTicket { get; set; }
    }
}
